# ─── Database ────────────────────────────────────────────
POSTGRES_DB=voucherdb
POSTGRES_USER=voucheruser
POSTGRES_PASSWORD=voucherpass

# ─── Backend ─────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=supersecretjwtkey_CHANGE_THIS_IN_PRODUCTION
JWT_EXPIRES_IN=7d

# ─── Frontend ────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000/api
# ─── PayPal config ─────────────────────────────────────────
REACT_APP_PAYPAL_CLIENT_ID=nhập_client_id_của_bạn_vào_đây
PAYPAL_CLIENT_ID=nhập_client_id_của_bạn_vào_đây
PAYPAL_CLIENT_SECRET=nhập_secret_của_bạn_vào_đây
